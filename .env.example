# Copy this file to one of:
# - .env.development
# - .env.test
# - .env.production
#
# The tracked workspace defaults already provide:
# - development => https://api-dev.sdkwork.com
# - test        => https://api-test.sdkwork.com
# - production  => https://api.sdkwork.com

# Desktop app runtime environment.
VITE_APP_ENV=development

# Shared backend API base URL used by app sdk clients and update checks.
VITE_API_BASE_URL=https://api-dev.sdkwork.com

# Canonical public user-center runtime contract.
# Switch to builtin-local or external-user-center in private deployments when needed.
VITE_AGENT_STUDIO_USER_CENTER_MODE=sdkwork-cloud-app-api
VITE_AGENT_STUDIO_USER_CENTER_PROVIDER_KEY=claw-studio-app-api
VITE_AGENT_STUDIO_USER_CENTER_LOCAL_API_BASE_PATH=/api/app/v1/user-center

# Private gateway/server user-center bridge variables.
# Do not expose these values through VITE_* browser env vars.
# AGENT_STUDIO_USER_CENTER_APP_API_BASE_URL=https://app-api.sdkwork.com
# AGENT_STUDIO_USER_CENTER_SECRET_ID=
# AGENT_STUDIO_USER_CENTER_SHARED_SECRET=
# AGENT_STUDIO_USER_CENTER_EXTERNAL_BASE_URL=https://identity.example.com

# Keep real secrets in .env.development.local or another ignored local env file.
# Browser and desktop Vite env files must not inject root access tokens.

# Optional OAuth provider list for the auth center. Comma-separated; defaults to
# wechat,douyin,github,google when left blank.
VITE_AUTH_OAUTH_PROVIDERS=

# Optional auth method configuration. Comma-separated; defaults keep all standard flows enabled.
VITE_AUTH_LOGIN_METHODS=password,phoneCode,emailCode
VITE_AUTH_REGISTER_METHODS=email,phone
VITE_AUTH_RECOVERY_METHODS=email,phone
VITE_AUTH_QR_LOGIN_ENABLED=true
VITE_AUTH_OAUTH_LOGIN_ENABLED=true

# Desktop update configuration.
VITE_APP_ID=10001
VITE_RELEASE_CHANNEL=stable
VITE_DISTRIBUTION_ID=global
VITE_PLATFORM=desktop
VITE_TIMEOUT=30000
VITE_ENABLE_STARTUP_UPDATE_CHECK=true

# Optional local server build bridge controls for Windows hosts packaging Linux targets.
# Example: pnpm server:build -- --target x86_64-unknown-linux-gnu
SDKWORK_SERVER_BUILD_WSL_DISTRO=
SDKWORK_SERVER_BUILD_DISABLE_WSL=false
