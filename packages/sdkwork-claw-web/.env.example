# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=MY_APP_URL

# AI generation features are instance-backed. Start or select an OpenClaw-compatible
# instance and apply real provider credentials through Provider Center instead of
# injecting a browser-side Gemini key.

# Shared backend API base URL for typed frontend infrastructure clients.
VITE_API_BASE_URL=http://localhost:8080

# Browser auth must flow through session state or a trusted host boundary, never Vite root tokens.

# Optional OAuth provider list for the auth center. Comma-separated; defaults to
# wechat,douyin,github,google when left blank.
VITE_AUTH_OAUTH_PROVIDERS=

# Optional auth method configuration. Comma-separated; defaults keep all standard flows enabled.
VITE_AUTH_LOGIN_METHODS=password,phoneCode,emailCode
VITE_AUTH_REGISTER_METHODS=email,phone
VITE_AUTH_RECOVERY_METHODS=email,phone
VITE_AUTH_QR_LOGIN_ENABLED=true
VITE_AUTH_OAUTH_LOGIN_ENABLED=true

# Backend app id reserved for desktop update checks.
VITE_APP_ID=10001

# Release channel reserved for desktop update checks.
VITE_RELEASE_CHANNEL=stable


# SDKWork private bootstrap credential (blank in tracked files).
SDKWORK_ACCESS_TOKEN=
