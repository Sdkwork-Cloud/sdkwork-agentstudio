# Desktop runtime environment.
VITE_APP_ENV=development

# Backend API base URL used for desktop update checks.
VITE_API_BASE_URL=http://localhost:8080

# Desktop update checks use host-mediated credentials when required, not Vite root tokens.

# Optional OAuth provider list for the auth center. Comma-separated; defaults to
# wechat,douyin,github,google when left blank.
VITE_AUTH_OAUTH_PROVIDERS=

# Optional auth method configuration. Comma-separated; defaults keep all standard flows enabled.
VITE_AUTH_LOGIN_METHODS=password,phoneCode,emailCode
VITE_AUTH_REGISTER_METHODS=email,phone
VITE_AUTH_RECOVERY_METHODS=email,phone
VITE_AUTH_QR_LOGIN_ENABLED=true
VITE_AUTH_OAUTH_LOGIN_ENABLED=true

# Backend app id for POST /app/v3/api/app/update/check.
VITE_APP_ID=10001

# Desktop release channel.
VITE_RELEASE_CHANNEL=stable

# Desktop distribution manifest id.
VITE_DISTRIBUTION_ID=global

# Force desktop mode when running the shell outside native Tauri.
VITE_PLATFORM=desktop

# Shared HTTP timeout in milliseconds.
VITE_TIMEOUT=30000

# Enable the startup update check in the desktop shell.
VITE_ENABLE_STARTUP_UPDATE_CHECK=true


# SDKWork private bootstrap credential (blank in tracked files).
SDKWORK_ACCESS_TOKEN=
