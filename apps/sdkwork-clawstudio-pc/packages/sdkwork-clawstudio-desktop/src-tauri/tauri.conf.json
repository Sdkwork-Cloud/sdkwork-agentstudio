{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claw Studio",
  "version": "0.1.0",
  "identifier": "com.sdkwork.claw-studio",
  "build": {
    "beforeDevCommand": "pnpm run dev:tauri",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1426"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Claw Studio",
        "width": 1440,
        "height": 900,
        "visible": false,
        "fullscreen": false,
        "resizable": true,
        "decorations": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "foundation/components/",
      "generated/bundled/",
      "../dist/",
      "resources/openclaw/"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
