{
  "name": "@sdkwork/clawstudio-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "sdkwork-run-node ../../scripts/run-vite-host.mjs serve --host 0.0.0.0 --port 3001 --mode development",
    "dev:test": "sdkwork-run-node ../../scripts/run-vite-host.mjs serve --host 0.0.0.0 --port 3001 --mode test",
    "build": "sdkwork-run-node ../../scripts/prepare-shared-sdk-packages.mjs && sdkwork-run-node ../../scripts/run-vite-host.mjs build --mode production && sdkwork-run-node ../../scripts/check-web-performance-budget.mjs",
    "build:dev": "sdkwork-run-node ../../scripts/prepare-shared-sdk-packages.mjs && sdkwork-run-node ../../scripts/run-vite-host.mjs build --mode development",
    "build:test": "sdkwork-run-node ../../scripts/prepare-shared-sdk-packages.mjs && sdkwork-run-node ../../scripts/run-vite-host.mjs build --mode test",
    "build:prod": "sdkwork-run-node ../../scripts/prepare-shared-sdk-packages.mjs && sdkwork-run-node ../../scripts/run-vite-host.mjs build --mode production && sdkwork-run-node ../../scripts/check-web-performance-budget.mjs",
    "preview": "vite preview",
    "clean": "sdkwork-run-node ../../scripts/remove-path.mjs dist",
    "lint": "sdkwork-run-node ../../scripts/run-workspace-tsc.mjs --noEmit"
  },
  "dependencies": {
    "@sdkwork/clawstudio-i18n": "workspace:*",
    "@sdkwork/clawstudio-shell": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.5.2",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.3"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
