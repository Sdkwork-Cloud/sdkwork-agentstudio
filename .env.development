# Claw Studio development environment
VITE_APP_ENV=development
VITE_API_BASE_URL=https://api-dev.sdkwork.com
VITE_CLAW_STUDIO_USER_CENTER_MODE=sdkwork-cloud-app-api
VITE_CLAW_STUDIO_USER_CENTER_PROVIDER_KEY=claw-studio-app-api
VITE_CLAW_STUDIO_USER_CENTER_LOCAL_API_BASE_PATH=/api/app/v1/user-center
# Keep committed defaults secret-free and host-mediated.
VITE_APP_ID=10001
VITE_RELEASE_CHANNEL=stable
VITE_DISTRIBUTION_ID=global
VITE_PLATFORM=desktop
VITE_TIMEOUT=30000
VITE_ENABLE_STARTUP_UPDATE_CHECK=true
